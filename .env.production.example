# Architex production environment example for architex.co.za
# Copy to the hosting control panel or a private .env.production file. Do not commit real secrets.

NODE_ENV=production
PORT=3000

# Public Firebase web config
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=architex.co.za
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_DATABASE_ID=

# Firebase Admin service account JSON or base64-encoded JSON
FIREBASE_SERVICE_ACCOUNT=
# FIREBASE_SERVICE_ACCOUNT_KEY=

# Blob/file storage used by /api/files/upload
BLOB_READ_WRITE_TOKEN=

# AI/provider keys required by enabled workflows
GEMINI_API_KEY=
NVIDIA_API_KEY=

# Optional payment/provider settings. Keep disabled until human-confirmed production setup is complete.
PAYFAST_MERCHANT_ID=
PAYFAST_MERCHANT_KEY=
PAYFAST_PASSPHRASE=
PAYFAST_SANDBOX=true
