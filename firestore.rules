rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function getUserData() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data
        : null;
    }
    
    function hasRole(role) {
      return isAuthenticated() && getUserData() != null && getUserData().role == role;
    }
    
    function isAdmin() {
      return isAuthenticated() && (
        (request.auth.token.email != null && request.auth.token.email.matches('gm\\.tarb@gmail\\.com|leor@slutzkin\\.co\\.za')) ||
        request.auth.token.admin == true ||
        (getUserData() != null && getUserData().role == 'admin')
      );
    }
    
    function isVerifiedArchitect() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/architect_verifications/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/architect_verifications/$(request.auth.uid)).data.status == 'verified';
    }

    function isProjectParticipant(jobId) {
      return isAuthenticated() && (
        getJob(jobId).data.clientId == request.auth.uid ||
        getJob(jobId).data.selectedArchitectId == request.auth.uid ||
        isAdmin()
      );
    }
    
    function getJob(jobId) {
      return get(/databases/$(database)/documents/jobs/$(jobId));
    }

    function isProjectTeamMemberAt(projectData, index) {
      return projectData.teamMembers is list &&
        projectData.teamMembers.size() > index &&
        projectData.teamMembers[index].userId == request.auth.uid &&
        projectData.teamMembers[index].status == 'active';
    }

    function isProjectTeamMember(projectData) {
      return isAuthenticated() && (
        isProjectTeamMemberAt(projectData, 0) ||
        isProjectTeamMemberAt(projectData, 1) ||
        isProjectTeamMemberAt(projectData, 2) ||
        isProjectTeamMemberAt(projectData, 3) ||
        isProjectTeamMemberAt(projectData, 4) ||
        isProjectTeamMemberAt(projectData, 5) ||
        isProjectTeamMemberAt(projectData, 6) ||
        isProjectTeamMemberAt(projectData, 7) ||
        isProjectTeamMemberAt(projectData, 8) ||
        isProjectTeamMemberAt(projectData, 9) ||
        isProjectTeamMemberAt(projectData, 10) ||
        isProjectTeamMemberAt(projectData, 11) ||
        isProjectTeamMemberAt(projectData, 12) ||
        isProjectTeamMemberAt(projectData, 13) ||
        isProjectTeamMemberAt(projectData, 14) ||
        isProjectTeamMemberAt(projectData, 15) ||
        isProjectTeamMemberAt(projectData, 16) ||
        isProjectTeamMemberAt(projectData, 17) ||
        isProjectTeamMemberAt(projectData, 18) ||
        isProjectTeamMemberAt(projectData, 19)
      );
    }

    function isProjectParticipantByData(projectData) {
      return isAuthenticated() && (
        isAdmin() ||
        projectData.clientId == request.auth.uid ||
        projectData.leadArchitectId == request.auth.uid ||
        isProjectTeamMember(projectData)
      );
    }

    function isParticipantLifecycleUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        'currentStage',
        'stageHistory',
        'updatedAt'
      ]);
    }

    // Users collection
    match /users/{userId} {
      // Allow reading user profiles if authenticated
      allow read: if isAuthenticated();
      
       allow create: if isAuthenticated() && isOwner(userId) && 
         request.resource.data.keys().hasAll(['uid', 'email', 'displayName', 'role', 'createdAt']) &&
         request.resource.data.role in ['client', 'architect', 'admin', 'freelancer', 'bep'];

      allow update: if isAuthenticated() && (
        (isOwner(userId) && 
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(
            ['displayName', 'bio', 'updatedAt', 'fcmTokens', 'notificationPreferences', 'professionalLabel', 'professionalLabels', 'region', 'nhbrcNumber', 'cidbGrading', 'hasPIInsurance', 'tradeLicense', 'projectType', 'budgetRange', 'sacapNumber', 'experienceYears', 'mainSpecialization']
          )
        ) || isAdmin()
      );
      allow delete: if isAdmin();
    }

    // Jobs collection
    match /jobs/{jobId} {
      allow read: if (resource.data.status == 'open') || 
                   (isAuthenticated() && (
                     resource.data.clientId == request.auth.uid ||
                     resource.data.selectedArchitectId == request.auth.uid ||
                     isAdmin()
                   ));
      allow create: if isAuthenticated() && hasRole('client') &&
        request.resource.data.clientId == request.auth.uid &&
        request.resource.data.keys().hasAll(['clientId', 'title', 'description', 'budget', 'status', 'createdAt']);
      allow update: if isAuthenticated() && (
        isAdmin() ||
        (resource.data.clientId == request.auth.uid &&
          request.resource.data.clientId == resource.data.clientId &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['title', 'description', 'requirements', 'deadline', 'budget', 'category', 'location', 'status', 'selectedArchitectId', 'updatedAt', 'cancelledAt', 'cancellationReason', 'statusHistory'])) ||
        (resource.data.selectedArchitectId == request.auth.uid &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt', 'statusHistory']))
      );
      allow delete: if isAdmin();

      // Applications subcollection
      match /applications/{appId} {
        allow read: if isAuthenticated() && (
          isAdmin() ||
          getJob(jobId).data.clientId == request.auth.uid ||
          resource.data.architectId == request.auth.uid
        );
        allow create: if isAuthenticated() && 
          hasRole('architect') &&
          request.resource.data.architectId == request.auth.uid;
        allow update: if isAuthenticated() && (
          (getJob(jobId).data.clientId == request.auth.uid) ||
          (resource.data.architectId == request.auth.uid &&
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'withdrawnAt', 'notes', 'updatedAt'])) ||
          isAdmin()
        );
        allow delete: if false;
      }

      // Submissions subcollection
      match /submissions/{subId} {
        allow read: if isAuthenticated() && (
          isAdmin() ||
          getJob(jobId).data.clientId == request.auth.uid ||
          resource.data.architectId == request.auth.uid
        );
        allow create: if isAuthenticated() && (
          (hasRole('architect') &&
            request.resource.data.architectId == request.auth.uid &&
            getJob(jobId).data.selectedArchitectId == request.auth.uid) ||
          (hasRole('client') &&
            getJob(jobId).data.clientId == request.auth.uid) ||
          isAdmin()
        );
        allow update: if isAuthenticated() && (
          isAdmin() ||
          (resource.data.architectId == request.auth.uid && 
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt', 'aiFeedback', 'aiStructuredFeedback', 'findings', 'signOffChecklist', 'riskStatus', 'executionMode', 'visualReportUrl', 'architectComment', 'traceability']))
        );
        allow delete: if false;
      }

      // Delegated tasks subcollection
      match /tasks/{taskId} {
        allow read: if isAuthenticated() && (
          isAdmin() ||
          getJob(jobId).data.clientId == request.auth.uid ||
          resource.data.architectId == request.auth.uid ||
          resource.data.assigneeId == request.auth.uid
        );
        allow create: if isAuthenticated() && 
          request.resource.data.architectId == request.auth.uid &&
          getJob(jobId).data.selectedArchitectId == request.auth.uid;
        allow update: if isAuthenticated() && (
          resource.data.architectId == request.auth.uid ||
          resource.data.assigneeId == request.auth.uid
        );
        allow delete: if isAuthenticated() && 
          resource.data.architectId == request.auth.uid;
      }
    }

    // Disputes collection
    match /disputes/{disputeId} {
      // Admin collection queries cannot safely call isAdmin() when that helper
      // reads the queried collection via getUserData(); use token/email checks
      // for list reads and keep owner/participant checks for document reads.
      allow list: if isAuthenticated() && (
        (request.auth.token.email != null && request.auth.token.email.matches('gm\\.tarb@gmail\\.com|leor@slutzkin\\.co\\.za')) ||
        request.auth.token.admin == true
      );
      allow get: if isAuthenticated() && (
        isAdmin() ||
        resource.data.filedBy == request.auth.uid ||
        resource.data.filedAgainst == request.auth.uid ||
        isProjectParticipant(resource.data.jobId)
      );
      allow create: if isAuthenticated() &&
        request.resource.data.filedBy == request.auth.uid &&
        isProjectParticipant(request.resource.data.jobId) &&
        request.resource.data.keys().hasAll(['jobId', 'filedBy', 'reason', 'requestedResolution', 'status', 'createdAt']) &&
        request.resource.data.status == 'open';
      allow update: if isAdmin();
      allow delete: if false;
    }

    // Projects collection
    match /projects/{projectId} {
      allow read: if isProjectParticipantByData(resource.data);
      allow create: if isAuthenticated() && (
        isAdmin() || request.resource.data.clientId == request.auth.uid
      );
      allow update: if isAuthenticated() && (
        isAdmin() ||
        (isProjectParticipantByData(resource.data) && isParticipantLifecycleUpdate())
      );
      allow delete: if isAdmin();
    }

    // Collection Group matches for Admin Dashboard
    match /{path=**}/submissions/{subId} {
      allow read: if isAuthenticated() && isAdmin();
    }

    match /{path=**}/applications/{appId} {
      allow read: if isAuthenticated() && (
        isAdmin() || resource.data.architectId == request.auth.uid
      );
    }

    // Reviews collection
    match /reviews/{reviewId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && 
        request.resource.data.fromId == request.auth.uid &&
        request.resource.data.keys().hasAll(['jobId', 'fromId', 'toId', 'rating', 'comment', 'type', 'createdAt']);
      allow update: if false;
      allow delete: if isAdmin();
    }

     // Notifications collection
     match /notifications/{notificationId} {
       allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
       // Only admins or server-side identities can create notifications for arbitrary users.
       // Users may create notifications for themselves.
       allow create: if 
         isAdmin() ||
         request.resource.data.userId == request.auth.uid;
       allow update: if isAuthenticated() && 
         resource.data.userId == request.auth.uid &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead', 'readAt']);
       allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
     }

// Messages collection
 match /messages/{messageId} {
 allow read: if isAuthenticated() && (
 resource.data.senderId == request.auth.uid ||
 getJob(resource.data.jobId).data.clientId == request.auth.uid ||
 getJob(resource.data.jobId).data.selectedArchitectId == request.auth.uid
 );
 allow create: if isAuthenticated() && (
 request.resource.data.senderId == request.auth.uid &&
 (getJob(request.resource.data.jobId).data.clientId == request.auth.uid ||
 getJob(request.resource.data.jobId).data.selectedArchitectId == request.auth.uid)
 );
 allow update: if isAuthenticated() && resource.data.senderId != request.auth.uid && (getJob(resource.data.jobId).data.clientId == request.auth.uid || getJob(resource.data.jobId).data.selectedArchitectId == request.auth.uid) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead', 'readAt']);
 allow delete: if false;
 }

    // Conversations collection
    match /conversations/{conversationId} {
      allow read: if isAuthenticated() && (
        resource.data.clientId == request.auth.uid ||
        resource.data.architectId == request.auth.uid
      );
      allow create: if isAuthenticated() && (
        request.resource.data.clientId == request.auth.uid ||
        request.resource.data.architectId == request.auth.uid
      );
      allow update: if isAuthenticated() && (
        resource.data.clientId == request.auth.uid ||
        resource.data.architectId == request.auth.uid
      );
      allow delete: if false;
    }

    // Architect verifications
    match /architect_verifications/{userId} {
      allow read: if isAuthenticated() && (isOwner(userId) || isAdmin());
      allow create: if isAuthenticated() && isOwner(userId) &&
        request.resource.data.keys().hasAll(['userId', 'status', 'submittedAt']);
      allow update: if isAuthenticated() && isAdmin();
      allow delete: if isAdmin();
    }

    // Architect profiles
    match /architect_profiles/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isOwner(userId);
      allow update: if isAuthenticated() && isOwner(userId);
      allow delete: if isAdmin();
    }

    // Payments collection
    match /payments/{paymentId} {
      allow read: if isAuthenticated() && (
        resource.data.payerId == request.auth.uid ||
        resource.data.payeeId == request.auth.uid ||
        isAdmin()
      );
      allow create: if isAuthenticated() && isAdmin();
      allow update: if isAuthenticated() && isAdmin();
      allow delete: if false;
    }

    // Escrow collection
    match /escrow/{jobId} {
      allow read: if isAuthenticated() && (
        isAdmin() ||
        getJob(jobId).data.clientId == request.auth.uid ||
        getJob(jobId).data.selectedArchitectId == request.auth.uid
      );
      allow create: if isAuthenticated() && isAdmin();
      allow update: if isAuthenticated() && isAdmin();
      allow delete: if false;
    }

    // System settings (admin only)
    match /system_settings/{document} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Agents collection
    match /agents/{agentId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // System logs (admin only read, auth create)
    match /system_logs/{logId} {
      allow read: if isAuthenticated() && isAdmin();
      allow create: if isAuthenticated();
      allow update: if false;
      allow delete: if isAuthenticated() && isAdmin();
    }

    // Council submissions
    match /council_submissions/{submissionId} {
      allow read: if isAuthenticated() && (
        isAdmin() ||
        resource.data.userId == request.auth.uid ||
        (resource.data.jobId != null &&
         (getJob(resource.data.jobId).data.clientId == request.auth.uid ||
          getJob(resource.data.jobId).data.selectedArchitectId == request.auth.uid))
      );
      allow create: if isAuthenticated() && (
        isAdmin() ||
        request.resource.data.userId == request.auth.uid
      );
      allow update: if isAuthenticated() && (
        isAdmin() ||
        resource.data.userId == request.auth.uid
      );
      allow delete: if false;
    }

    // Invoices collection
    match /invoices/{invoiceId} {
      allow read: if isAuthenticated() && (
        isAdmin() ||
        resource.data.clientId == request.auth.uid ||
        resource.data.architectId == request.auth.uid
      );
      allow create: if isAuthenticated() && (
        isAdmin() ||
        (hasRole('architect') && request.resource.data.architectId == request.auth.uid)
      );
      allow update: if isAuthenticated() && (
        isAdmin() ||
        (resource.data.architectId == request.auth.uid &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'pdfUrl', 'updatedAt']))
      );
      allow delete: if isAdmin();
    }

    // Uploaded files collection
    match /uploaded_files/{fileId} {
      allow read: if isAuthenticated() && (
        resource.data.uploadedBy == request.auth.uid ||
        isAdmin() ||
        (resource.data.jobId is string && isProjectParticipant(resource.data.jobId))
      );
      allow create: if isAuthenticated() && request.resource.data.uploadedBy == request.auth.uid;
      allow delete: if isAuthenticated() && (resource.data.uploadedBy == request.auth.uid || isAdmin());
    }

    // Agent Knowledge collection
    match /agent_knowledge/{entryId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && (isAdmin() || request.resource.data.status == 'pending_review');
      allow update: if isAuthenticated() && (
        isAdmin() ||
        (resource != null &&
         resource.data.submittedBy == request.auth.uid &&
         resource.data.status == 'pending_review' &&
         request.resource.data.status == resource.data.status)
      );
      allow delete: if isAuthenticated() && isAdmin();
    }

    // Default deny for everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
