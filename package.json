{
  "name": "architex",
  "private": true,
  "version": "1.0.0",
  "engines": {
    "node": "20.x"
  },
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "start": "NODE_ENV=production tsx server.ts",
    "start:api:host": "NODE_ENV=production DISABLE_NOTIFICATION_WORKER=true tsx api-server.ts",
    "build": "vite build",
    "vercel-build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit -p tsconfig.app.json",
    "lint:tests": "tsc --noEmit",
    "test": "node scripts/run-tests.mjs",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "docs:api-contracts": "node scripts/validate-api-contracts.mjs",
    "predeploy:check": "node scripts/predeploy-check.mjs",
    "smoke:api": "node scripts/cpanel-api-smoke.mjs",
    "deploy:api:bundle": "npm run predeploy:check && node scripts/build-cpanel-api-bundle.mjs",
    "deploy:bundle": "npm run deploy:static:bundle && npm run predeploy:check",
    "install:deps": "npm install",
    "deploy:static:bundle": "npm run build && node scripts/build-static-upload-bundle.mjs"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.0",
    "@fontsource-variable/geist": "^5.2.8",
    "@google/genai": "^1.29.0",
    "@radix-ui/react-avatar": "^1.1.0",
    "@radix-ui/react-slider": "^1.2.0",
    "@radix-ui/react-slot": "^1.2.4",
    "@tailwindcss/vite": "^4.1.14",
    "@types/cors": "^2.8.19",
    "@types/js-md5": "^0.8.0",
    "@types/three": "^0.184.1",
    "@vercel/blob": "^2.3.3",
    "@vitejs/plugin-react": "^5.0.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cors": "^2.8.6",
    "date-fns": "^4.1.0",
    "dompurify": "^3.2.0",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "firebase": "^12.12.0",
    "firebase-admin": "^13.8.0",
    "framer-motion": "^12.38.0",
    "isomorphic-dompurify": "^2.21.0",
    "js-md5": "^0.8.3",
    "lucide-react": "^0.546.0",
    "multer": "^1.4.5-lts.1",
    "next-themes": "^0.4.6",
    "pdf-lib": "^1.17.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "shadcn": "^4.2.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "three": "^0.184.0",
    "tw-animate-css": "^1.4.0",
    "vite": "^6.2.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/dompurify": "^3.0.5",
    "@types/express": "^4.17.21",
    "@types/express-rate-limit": "^5.1.3",
    "@types/jest": "^29.5.14",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.14.0",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.5",
    "autoprefixer": "^10.4.21",
    "cross-env": "^10.1.0",
    "express-rate-limit": "^7.5.1",
    "firebase-tools": "^15.15.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jsdom": "^29.1.1",
    "supertest": "^7.2.2",
    "tailwindcss": "^4.1.14",
    "ts-jest": "^29.1.0",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vitest": "^4.1.5"
  }
}
