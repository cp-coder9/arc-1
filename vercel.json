{
  "version": 2,
  "buildCommand": "vite build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "functions": {
    "api/index.ts": {
      "maxDuration": 60,
      "memory": 512
    },
    "api/notifications/worker.ts": {
      "maxDuration": 60,
      "memory": 256
    }
  },
  "crons": [
    {
      "path": "/api/notifications/worker",
      "schedule": "0 0 * * *"
    }
  ],
  "routes": [
    {
      "src": "/api/notifications/worker",
      "dest": "/api/notifications/worker.ts"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/index.ts"
    },
    {
      "src": "/(.*\\.(js|css|ico|png|jpg|jpeg|svg|woff|woff2|ttf|eot|map)$)",
      "dest": "/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}
